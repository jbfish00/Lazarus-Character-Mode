# Never commit ROMs, saves, or savestates
rom/
*.gba
*.sav
*.ss[0-9]
*.State

# Build outputs (patched ROMs, test logs/screenshots, compile intermediates —
# all regenerable via tools/inject_character_mode.py and the test suite).
# The shipped .bps is committed deliberately.
build/*
!build/lazarus_cm.bps

# Emulator/analysis workspaces
ghidra_project/
tools/savestates/

# Python
__pycache__/
*.pyc
